EXERCÍCIO 1 - ANO BISSEXTO

/*
 * Instituição: etecvav
 * Data: 02/04/2026
 * Autor: Larissa dos Santos Mascoti
 * Descricao: Ler um ano e verificar se ele é bissexto.
 * 
 */
programa
{
	
	funcao inicio()
	{
		inteiro ano

    //Escreva ano
     escreva("Escreva um ano:\n")
	leia(ano)

     //Limpar console
     limpa()

      //Calcule o ano para ver se é bissexto 
      se ((ano % 4 == 0 e ano % 100 != 0) ou (ano % 400 == 0)) {
      escreva(ano, " é bissexto")
}

      //escreva se o ano não é bissexto
      senao {
      escreva(ano , " não é bissexto")
}
		
	}
}


EXERCÍCIO 2 - CLASSIFICAÇÃO DE TRIÂNGULO

/*
 * Instituição: etecvav
 * Data: 02/04/2026
 * Autor: Kevin William da Silva Souza
 * Descricao: Ler três números e verificar se eles formam um triângulo. Caso formem, identificar se é:
  Equilátero (todos os lados iguais)
  Isósceles (dois lados iguais)
  Escaleno (todos os lados diferentes)
*/
programa
{
	funcao inicio()
	{
		//  Declaração das variáveis
		real a, b, c

		//  Entrada de dados
		escreva("Digite o valor do lado A: ")
		leia(a)
		escreva("Digite o valor do lado B: ")
		leia(b)
		escreva("Digite o valor do lado C: ")
		leia(c)

		limpa() // Limpa a tela para organizar o resultado

	
		
		// Primeiro, verificamos a condição de existência do triângulo
		se (a < b + c e b < a + c e c < a + b) 
		{
			escreva("Os lados formam um triângulo: ")

			// Classificação quanto aos lados
			se (a == b e b == c) 
			{
				escreva("EQUILÁTERO\n")
				escreva("Motivo: Todos os lados são iguais.")
			}
			senao se (a == b ou a == c ou b == c) 
			{
				escreva("ISÓSCELES\n")
				escreva("Motivo: Dois lados são iguais.")
			}
			senao 
			
			{
				escreva("ESCALENO\n")
				escreva("Motivo: Todos os lados são diferentes.")
			}
		}
		senao 
		{
			// Caso não forme um triângulo
			escreva(" Não forma um triângulo essas medidas.\n")
			
		}
	}
}


EXERCÍCIO 3 - DESCONTOS

/*
 * Instituição: etecvav
 * Data: 09/04/2026
 * Autor: Kevin William da Silva Souza e Larissa dos Santos Mascoti
 * Descricao: Ler o valor de uma compra e calcular o desconto de acordo com as seguintes regras:
Menor que R$100 → sem desconto
Entre R$100 e R$500 → 10% de desconto
Acima de R$500 → 20% de desconto
Ao final, exibir o valor após o desconto.
*/
programa
{
   funcao inicio()
   {
   	
   	//declarar as varieveis
      real valor, desconto, valor_final

      //escreva o valor da compra
      escreva("digite o valor da compra")

     //leia o valor
      leia(valor)
 
      se (valor < 100) {
         desconto = 0.0
         escreva("não obteve desconto")
      }
      senao {
         se (valor <= 500) {
            desconto = valor * 10 / 100
         }
         senao {
            desconto = valor * 20 / 100
         }
      }

      valor_final = valor - desconto

      //escreva o valor da compra
      escreva("Valor da compra: ", valor)

     //limpar o console
      limpa()

      //escrever valor final
      escreva("Valor final com desconto: ", valor_final)
   }
}

EXERCÍCIO 4 - ESTACIONAMENTO

/*
 * Instituição: etecvav
 * Data: 02/04/2026
 * Autor: Larissa dos Santos Mascoti
 * Descricao:Ler o tempo de permanência de um veículo em um estacionamento e calcular o valor a pagar, considerando:
Até 2 horas → R$ 2,00 por hora
Após 2 horas →
As 2 primeiras continuam custando R$ 2,00 cada
As horas adicionais custam R$ 1,00 por hora
 * 
 */
programa
{
	
	funcao inicio()
	{
	
	real tempo, preco

    leia(tempo)

  se (tempo <= 2) entao
   preco <- tempo * 2
   
  se
  preco <- (2 * 2) + ((tempo - 2) * 1)
  

  escreva("Tempo: ", tempo, " horas")
  escreva("Valor a pagar: R$ ", preco)
	}
}


