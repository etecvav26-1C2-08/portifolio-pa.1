//Descricao:Ler vários números até que a soma desses números seja maior que 100. Exibir a multiplicação dos números lidos.
 
// Online C++ compiler to run C++ program online
#include <iostream>

using namespace std;

int main() {
    // Inicialização das variáveis
    // Usamos 'double' para permitir números com vírgula e valores grandes
    double numero;
    double soma = 0;
    double multiplicacao = 1; // Começa em 1 para não zerar o produto

    cout << "--- Acumulador de Soma e Multiplicacao ---" << endl;
    cout << "O programa para quando a soma ultrapassar 100." << endl;

    // Laço de repetição: executa ENQUANTO a soma for menor ou igual a 100
    while (soma <= 100) {
        cout << "Digite um numero: ";
        cin >> numero;

        // Atualiza os acumuladores
        soma += numero;          // soma = soma + numero
        multiplicacao *= numero; // multiplicacao = multiplicacao * numero
        
        cout << "Soma atual: " << soma << endl;
    }

    // Saída final após sair do laço
    cout << "\n------------------------------------------" << endl;
    cout << "A soma passou de 100!" << endl;
    cout << "Resultado final da MULTIPLICACAO: " << multiplicacao << endl;
    cout << "Soma total alcancada: " << soma << endl;

    return 0;
}

