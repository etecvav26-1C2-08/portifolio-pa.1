 //Descricao:Ler um número para a parada final e outro número que representa um múltiplo. Exibir os múltiplos do número lido de 1 até o número final lido.
#include <stdio.h>

int main() {
    int final, multiplo;

    // 1. Entrada de dados
    printf("Digite o numero de parada final: ");
    scanf("%d", &final);
    printf("Digite o numero base (multiplo): ");
    scanf("%d", &multiplo);

    printf("\nMultiplos encontrados:\n");

    // 2. Laço de repetição de 1 até o final
    for (int i = 1; i <= final; i++) {
        
        // 3. Verificação lógica usando o operador de módulo (%)
        if (i % multiplo == 0) {
            printf("%d ", i);
        }
    }

    return 0;
}



