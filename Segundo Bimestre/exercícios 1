#include <iostream>
#include <iomanip> // Biblioteca para formatar as casas decimais

using namespace std;

int main() {
    int qtdPessoas;
    double altura, somaAlturas = 0, media;

    // 1. Entrada: Quantidade de pessoas
    cout << "Digite a quantidade de pessoas no grupo: ";
    cin >> qtdPessoas;

    // Validação simples: se for 0, não há como calcular média
    if (qtdPessoas <= 0) {
        cout << "Quantidade invalida!" << endl;
        return 0;
    }

    // 2. Processamento: Repetir a leitura conforme a quantidade informada
    for (int i = 1; i <= qtdPessoas; i++) {
        cout << "Digite a altura da pessoa " << i << " (em metros): ";
        cin >> altura;
        
        somaAlturas += altura; // Acumula a altura lida
    }

    // 3. Cálculo da média
    media = somaAlturas / qtdPessoas;

    // 4. Saída: Exibe com 2 casas decimais para ficar elegante
    cout << fixed << setprecision(2);
    cout << "\n--- Resultado ---" << endl;
    cout << "A soma das alturas e: " << somaAlturas << "m" << endl;
    cout << "A altura media do grupo e: " << media << "m" << endl;

    return 0;
}
